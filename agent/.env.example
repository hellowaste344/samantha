# ═══════════════════════════════════════════════════════════════════════════════
#  Samantha v2 — Environment configuration
#  Copy this file to agent/.env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Agent ─────────────────────────────────────────────────────────────────────
DOMAIN=zenonai.net

# -- Hugging Face --------------------------------------------------------------
HF_TOKEN=hf_your_token_here

# ── LLM — Ollama ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
# OLLAMA_MODEL=mistral
# OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120
OLLAMA_AUTO_START=true
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── STT — faster-whisper ──────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=small

# Device: cpu | cuda
WHISPER_DEVICE=cpu

# Compute type: int8 (fastest CPU) | float32 | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# CPU threads for CTranslate2
WHISPER_CPU_THREADS=4

# STT mode: rust_bridge (default) | voice | text
STT_MODE=rust_bridge

STT_LANGUAGE=en
AUDIO_SAMPLE_RATE=16000
MIC_PAUSE_DURATION=1.2
MIC_ENERGY_THRESHOLD=0.01

# Unix socket path for Rust ↔ Python IPC
AUDIO_SOCKET=/tmp/samantha_audio.sock

# ── TTS ────────────────────────────────────────────────────────────────────────
# Engine: edge | piper | pyttsx3 | none
TTS_ENGINE=edge
TTS_EDGE_VOICE=aria

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=false

# ── Local API bridge ──────────────────────────────────────────────────────────
API_ENABLED=true
API_PORT=7799

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
