# ═══════════════════════════════════════════════════════════════════════════════
#  Samantha — Environment configuration
#  Copy this file to agent/.env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Agent ─────────────────────────────────────────────────────────────────────
DOMAIN=zenonai.net

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── LLM — Ollama ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# llama3.2:3b is ~3× faster for JSON plans than deepseek-r1:7b.
# Switch to deepseek-r1:7b or mistral for higher reasoning accuracy.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=60
OLLAMA_AUTO_START=true
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
LLM_NUM_CTX=2048

# ── STT — faster-whisper ──────────────────────────────────────────────────────
# Model size: tiny (default, ~32× RT) | base | small (~6× RT) | medium | large-v3
WHISPER_MODEL=tiny

# Device: cpu | cuda
WHISPER_DEVICE=cpu

# Compute type: int8 (fastest CPU) | float32 | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# CPU threads for CTranslate2
WHISPER_CPU_THREADS=4

# STT mode: rust_bridge (default) | voice | text
STT_MODE=rust_bridge

STT_LANGUAGE=en
AUDIO_SAMPLE_RATE=16000
MIC_PAUSE_DURATION=1.0
MIC_ENERGY_THRESHOLD=0.01

# Unix socket path for Rust ↔ Python IPC
AUDIO_SOCKET=/tmp/samantha_audio.sock

# ── TTS ────────────────────────────────────────────────────────────────────────
# Engine: edge | piper | pyttsx3 | none
TTS_ENGINE=edge
TTS_EDGE_VOICE=aria

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=false

# ── Local API bridge ──────────────────────────────────────────────────────────
API_ENABLED=true
API_PORT=7799

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Screen capture pipeline ────────────────────────────────────────────────────
# Monitor index to capture (1 = primary, 2 = secondary, ...)
SCREEN_MONITOR=1

# YOLOv8 model. "yolov8n.pt" is auto-downloaded on first use (~6 MB).
# Swap for a fine-tuned UI model if you have one:
# YOLO_MODEL_PATH=/path/to/ui_detector.pt
YOLO_MODEL_PATH=yolov8n.pt

# OCR language (PaddleOCR code / Tesseract lang code)
OCR_LANGUAGE=en
